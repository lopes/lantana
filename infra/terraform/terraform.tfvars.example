# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit secrets.

# --- vSphere Connection ---
vsphere_server               = "vcenter.example.com"
vsphere_user                 = "administrator@vsphere.local"
vsphere_password             = "CHANGE_ME"
vsphere_allow_unverified_ssl = false

# --- Infrastructure ---
datacenter    = "DC1"
cluster       = "Cluster1"
datastore     = "datastore1"
resource_pool = ""
vm_folder     = "lantana"
vm_template   = "debian-13-template"

# --- Networking ---
wan_network = "VM Network"
lan_network = "Lantana-LAN" # Only needed for multi-node

# --- Deployment ---
operation_name  = "lantana"
deployment_mode = "single" # "single" or "multi"
ssh_public_key  = "ssh-ed25519 AAAA... user@host"

# --- Single-node sizing ---
single_node_cpus   = 2
single_node_memory = 4096
single_node_disk   = 60
