# /etc/lantana/honeywall/nftables/sensors/dionaea.nft
# Managed by Ansible.
#
# DNAT and accept rules are generated from dionaea_services × dionaea_service_catalog.
# Disable a service by removing it from dionaea_services in inventory.
{%- set tcp_pub_ports = [] %}
{%- set udp_pub_ports = [] %}
{%- for svc in dionaea_services %}
{%-   set s = dionaea_service_catalog[svc] %}
{%-   set _ = tcp_pub_ports.append(s.pub_port) %}
{%-   if s.transport == 'tcp_udp' %}
{%-     set _ = udp_pub_ports.append(s.pub_port) %}
{%-   endif %}
{%- endfor %}

table ip lantana_nat {
    chain prerouting {
{%- for svc in dionaea_services %}
{%-   set s = dionaea_service_catalog[svc] %}
        iifname $WAN_IF tcp dport {{ s.ext_port }} dnat to {{ network.sensors.sensor_01.ipv4.split('/')[0] }}:{{ s.pub_port }}
{%-   if s.transport == 'tcp_udp' %}
        iifname $WAN_IF udp dport {{ s.ext_port }} dnat to {{ network.sensors.sensor_01.ipv4.split('/')[0] }}:{{ s.pub_port }}
{%-   endif %}
{%- endfor %}
    }
}

table ip6 lantana_nat6 {
    chain prerouting {
{%- for svc in dionaea_services %}
{%-   set s = dionaea_service_catalog[svc] %}
        iifname $WAN_IF tcp dport {{ s.ext_port }} dnat to [{{ network.sensors.sensor_01.ipv6.split('/')[0] }}]:{{ s.pub_port }}
{%-   if s.transport == 'tcp_udp' %}
        iifname $WAN_IF udp dport {{ s.ext_port }} dnat to [{{ network.sensors.sensor_01.ipv6.split('/')[0] }}]:{{ s.pub_port }}
{%-   endif %}
{%- endfor %}
    }
}

table inet lantana_filter {
    chain input {
        ip daddr {{ network.sensors.sensor_01.ipv4.split('/')[0] }} tcp dport { {{ tcp_pub_ports | join(', ') }} } accept
        ip6 daddr {{ network.sensors.sensor_01.ipv6.split('/')[0] }} tcp dport { {{ tcp_pub_ports | join(', ') }} } accept
{%- if udp_pub_ports %}
        ip daddr {{ network.sensors.sensor_01.ipv4.split('/')[0] }} udp dport { {{ udp_pub_ports | join(', ') }} } accept
        ip6 daddr {{ network.sensors.sensor_01.ipv6.split('/')[0] }} udp dport { {{ udp_pub_ports | join(', ') }} } accept
{%- endif %}
    }

    chain forward {
        ip daddr {{ network.sensors.sensor_01.ipv4.split('/')[0] }} tcp dport { {{ tcp_pub_ports | join(', ') }} } accept
        ip6 daddr {{ network.sensors.sensor_01.ipv6.split('/')[0] }} tcp dport { {{ tcp_pub_ports | join(', ') }} } accept
{%- if udp_pub_ports %}
        ip daddr {{ network.sensors.sensor_01.ipv4.split('/')[0] }} udp dport { {{ udp_pub_ports | join(', ') }} } accept
        ip6 daddr {{ network.sensors.sensor_01.ipv6.split('/')[0] }} udp dport { {{ udp_pub_ports | join(', ') }} } accept
{%- endif %}
    }
}
