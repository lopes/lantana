# Managed by Ansible.
# SIP/VoIP signaling. Mirrors the bundled :nightly image's
# services-available/sip.yaml; absent the `users:` + `rtp:` blocks,
# dionaea silently refuses to start the SIP listener. Paths are relative
# to dionaea's working dir (/opt/dionaea/).
# No narrative integration -- we don't define narrative.services.sip.
# If a future op wants persona-customized SIP banners, add the key and
# substitute below.
- name: sip
  config:
    udp_ports:
      - 5060
    tcp_ports:
      - 5060
    users: "var/lib/dionaea/sip/accounts.sqlite"
    rtp:
      enable: true
      modes:
        - bistream
        - pcap
      pcap:
        path: "var/lib/dionaea/sip/rtp/{personality}/%Y-%m-%d/"
        filename: "%H:%M:%S_{remote_host}_{remote_port}_in.pcap"
    personalities:
      default:
        domain: "localhost"
        name: "softphone"
        personality: "generic"
    actions:
      bank-redirect:
        do: "redirect"
        params:
      play-hello:
        do: "play"
        params:
          file: "var/lib/dionaea/sip/hello.wav"
