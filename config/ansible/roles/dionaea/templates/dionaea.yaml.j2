# /etc/lantana/sensor/dionaea/dionaea.yaml
# Managed by Ansible.
#
# CONTRACT: every persona-facing string derives from narrative.yml. Never
# inline a literal banner/version/hostname/workgroup string in this file —
# the same OS persona has to read consistently across Cowrie SSH banners,
# Dionaea Samba/MySQL/MSSQL version strings, and the FTP greeting. Drift
# between any of these gives the deception away.
#
# Service set is controlled by `dionaea_services` (default in
# roles/dionaea/defaults/main.yml; override per-operation in inventory).

logging:
  default:
    handlers:
      - file

  file:
    filename: /opt/dionaea/var/log/dionaea/dionaea.log

handlers:
  log_json:
    handlers:
      - file_json

    file_json:
      filename: /opt/dionaea/var/log/dionaea/dionaea.json

services:
{%- if 'ftp' in dionaea_services %}

  ftp:
    bind:
      - "0.0.0.0:21"
      - "[::]:21"
    banner: "{{ narrative.services.ftp.banner }}"
{%- endif %}
{%- if 'http' in dionaea_services %}

  http:
    bind:
      - "0.0.0.0:80"
      - "[::]:80"
    headers:
      Server: "{{ narrative.services.http.server_header }}"
    root: /opt/dionaea/var/lib/dionaea/wwwroot
{%- endif %}
{%- if 'smb' in dionaea_services %}

  smb:
    bind:
      - "0.0.0.0:445"
      - "[::]:445"
    os_type: 2
    native_os: "{{ narrative.host.os_release }}"
    native_lm: "{{ narrative.services.smb.server_string }}"
    workgroup: "{{ narrative.services.smb.workgroup }}"
{%- endif %}
{%- if 'epmap' in dionaea_services %}

  epmap:
    bind:
      - "0.0.0.0:135"
      - "[::]:135"
{%- endif %}
{%- if 'mssql' in dionaea_services %}

  mssql:
    bind:
      - "0.0.0.0:1433"
      - "[::]:1433"
    version: "{{ narrative.services.mssql.version }}"
{%- endif %}
{%- if 'mysql' in dionaea_services %}

  mysql:
    bind:
      - "0.0.0.0:3306"
      - "[::]:3306"
    version: "{{ narrative.services.mysql.version }}"
{%- endif %}
{%- if 'sip' in dionaea_services %}

  sip:
    bind:
      - "0.0.0.0:5060"
      - "[::]:5060"
    udp:
      - "0.0.0.0:5060"
      - "[::]:5060"
{%- endif %}

downloads:
  dir: /opt/dionaea/var/lib/dionaea/binaries
  tmp_dir: /opt/dionaea/var/lib/dionaea/tmp
  max_file_size: 52428800

listen:
  default:
    - "0.0.0.0"
    - "::"
