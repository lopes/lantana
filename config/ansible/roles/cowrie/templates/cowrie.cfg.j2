# /etc/lantana/sensor/cowrie/cowrie.cfg
# Managed by Ansible

[honeypot]
hostname = {{ narrative.host.hostname }}
download_limit_size = 52428800
logtype = plain
auth_class = AuthRandom
auth_class_parameters = 2, 5, 10
log_path = /cowrie/cowrie-git/var/log/cowrie
state_path = /cowrie/cowrie-git/var/lib/cowrie

[shell]
hardware_platform = {{ narrative.host.hardware_platform }}
operating_system = {{ narrative.host.operating_system }}
arch = {{ narrative.host.architecture }}
kernel_version = {{ narrative.host.kernel_version }}
kernel_build_string = {{ narrative.host.kernel_build }}
ssh_version = {{ narrative.services.ssh.version }}

[ssh]
enabled = true
rsa_public_key = ${honeypot:state_path}/keys/ssh_host_rsa_key.pub
rsa_private_key = ${honeypot:state_path}/keys/ssh_host_rsa_key
ecdsa_public_key = ${honeypot:state_path}/keys/ssh_host_ecdsa_key.pub
ecdsa_private_key = ${honeypot:state_path}/keys/ssh_host_ecdsa_key
ed25519_public_key = ${honeypot:state_path}/keys/ssh_host_ed25519_key.pub
ed25519_private_key = ${honeypot:state_path}/keys/ssh_host_ed25519_key
public_key_auth = ssh-rsa,ssh-dss,ecdsa-sha2-nistp256,ssh-ed25519
version = {{ narrative.services.ssh.version }}
ciphers = aes128-ctr,aes192-ctr,aes256-ctr,aes256-cbc,aes192-cbc,aes128-cbc,3des-cbc,blowfish-cbc,cast128-cbc
macs = hmac-sha2-512,hmac-sha2-384,hmac-sha2-56,hmac-sha1,hmac-md5
compression = zlib@openssh.com,zlib,none
listen_endpoints = tcp6:2222:interface=\:\:
sftp_enabled = true
forwarding = true
forward_redirect = false
forward_tunnel = false
auth_none_enabled = false
auth_keyboard_interactive_enabled = true
auth_publickey_allow_any = true

[telnet]
enabled = true
listen_endpoints = tcp6:2223:interface=\:\:

[output_jsonlog]
enabled = true
