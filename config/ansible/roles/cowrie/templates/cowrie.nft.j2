# /etc/lantana/honeywall/nftables/sensors/cowrie.nft
# Managed by Ansible

table ip lantana_nat {
    chain prerouting {
        iifname $WAN_IF tcp dport 22 dnat to $SENSOR_IPV4:2222
        iifname $WAN_IF tcp dport 23 dnat to $SENSOR_IPV4:2223
    }
}

table ip6 lantana_nat6 {
    chain prerouting {
        iifname $WAN_IF tcp dport 22 dnat to $SENSOR_IPV6:2222
        iifname $WAN_IF tcp dport 23 dnat to $SENSOR_IPV6:2223
    }
}

table inet lantana_filter {
    chain input {
        ip daddr $SENSOR_IPV4 tcp dport { 2222, 2223 } accept
        ip6 daddr $SENSOR_IPV6 tcp dport { 2222, 2223 } accept
    }
}
