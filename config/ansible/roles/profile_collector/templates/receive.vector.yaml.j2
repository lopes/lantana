# /etc/vector/conf.d/receive.yaml
# Managed by Ansible

enrichment_tables:
  geoip_city:
    type: geoip
    path: /var/lib/lantana/collector/geoip/GeoLite2-City.mmdb
  geoip_asn:
    type: geoip
    path: /var/lib/lantana/collector/geoip/GeoLite2-ASN.mmdb

sources:
  receive_from_edges:
    type: vector
    address: "0.0.0.0:{{ network.collectors.collector_01.port }}"
    version: "2"

transforms:
  enrich_geo:
    type: remap
    inputs:
      - receive_from_edges
    source: |-
      ip = to_string(.src_ip) ?? to_string(.source.ip) ?? ""
      if ip != "" {
        city_data = get_enrichment_table_record("geoip_city", {"ip": ip}) ?? {}
        asn_data = get_enrichment_table_record("geoip_asn", {"ip": ip}) ?? {}
        # Vector's `geoip` enrichment_table type flattens GeoLite2-City
        # records into top-level columns (city_name / country_code /
        # region_code / latitude / longitude / timezone / postal_code /
        # metro_code) — NOT the MaxMind-native nested shape the
        # `maxminddb` Python library returns. Querying the nested paths
        # gave null on every event since op_alpha went live; the `?? ""`
        # default doesn't fire because `??` catches errors, not nulls.
        # For ASN, Vector passes the raw MaxMind record through (no
        # flattening), so the native `autonomous_system_*` keys work as-is.
        .geo.country_code = get(city_data, ["country_code"]) ?? ""
        .geo.region_code = get(city_data, ["region_code"]) ?? ""
        .geo.city = get(city_data, ["city_name"]) ?? ""
        .geo.latitude = get(city_data, ["latitude"]) ?? null
        .geo.longitude = get(city_data, ["longitude"]) ?? null
        .geo.timezone = get(city_data, ["timezone"]) ?? ""
        .geo.asn = get(asn_data, ["autonomous_system_number"]) ?? null
        .geo.isp = get(asn_data, ["autonomous_system_organization"]) ?? ""
      }

sinks:
  write_to_datalake:
    type: file
    inputs:
      - enrich_geo
    path: "/var/lib/lantana/datalake/bronze/dataset={{ '{{.dataset}}' }}/date=%Y-%m-%d/server={{ '{{.server}}' }}/events.json"
    encoding:
      codec: json
