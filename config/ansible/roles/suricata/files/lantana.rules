# Lantana custom Suricata rules for honeypot-specific detection
# SID range: 9000001-9000999
# Managed by Ansible

# =============================================================================
# SSH detection (complement Cowrie)
# =============================================================================

# SSH brute force: rapid connection attempts from same source
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"LANTANA SSH Brute Force"; flow:to_server,established; content:"SSH-"; threshold:type threshold, track by_src, count 5, seconds 60; classtype:attempted-admin; sid:9000001; rev:1;)

# SSH non-standard client banner (scripted tools)
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"LANTANA SSH Scripted Client (libssh)"; flow:to_server,established; content:"SSH-"; content:"libssh"; classtype:misc-activity; sid:9000002; rev:1;)

alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"LANTANA SSH Scripted Client (paramiko)"; flow:to_server,established; content:"SSH-"; content:"paramiko"; nocase; classtype:misc-activity; sid:9000003; rev:1;)

alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"LANTANA SSH Scripted Client (Go)"; flow:to_server,established; content:"SSH-"; content:"Go"; classtype:misc-activity; sid:9000004; rev:1;)

# =============================================================================
# SMB detection (complement Dionaea)
# =============================================================================

# SMB null session enumeration
alert tcp $EXTERNAL_NET any -> $HOME_NET 445 (msg:"LANTANA SMB Null Session Attempt"; flow:to_server,established; content:"|ff|SMB"; depth:4; content:"|73 00 00 00|"; distance:0; classtype:attempted-recon; sid:9000010; rev:1;)

# SMB brute force: rapid connection attempts
alert tcp $EXTERNAL_NET any -> $HOME_NET 445 (msg:"LANTANA SMB Brute Force"; flow:to_server,established; content:"|ff|SMB"; threshold:type threshold, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:9000011; rev:1;)

# =============================================================================
# MySQL detection (complement Dionaea)
# =============================================================================

# MySQL brute force: rapid authentication attempts
alert tcp $EXTERNAL_NET any -> $HOME_NET 3306 (msg:"LANTANA MySQL Brute Force"; flow:to_server,established; threshold:type threshold, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:9000020; rev:1;)

# =============================================================================
# FTP detection (complement Dionaea)
# =============================================================================

# FTP brute force: rapid USER commands
alert tcp $EXTERNAL_NET any -> $HOME_NET 21 (msg:"LANTANA FTP Brute Force"; flow:to_server,established; content:"USER "; threshold:type threshold, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:9000030; rev:1;)

# FTP anonymous login attempt
alert tcp $EXTERNAL_NET any -> $HOME_NET 21 (msg:"LANTANA FTP Anonymous Login"; flow:to_server,established; content:"USER anonymous"; nocase; classtype:misc-activity; sid:9000031; rev:1;)

# =============================================================================
# MSSQL detection (complement Dionaea)
# =============================================================================

# MSSQL brute force: rapid connection attempts
alert tcp $EXTERNAL_NET any -> $HOME_NET 1433 (msg:"LANTANA MSSQL Brute Force"; flow:to_server,established; threshold:type threshold, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:9000040; rev:1;)

# =============================================================================
# SIP detection (complement Dionaea)
# =============================================================================

# SIP OPTIONS scanning (VoIP enumeration)
alert udp $EXTERNAL_NET any -> $HOME_NET 5060 (msg:"LANTANA SIP OPTIONS Scan"; content:"OPTIONS sip:"; nocase; threshold:type threshold, track by_src, count 5, seconds 30; classtype:attempted-recon; sid:9000050; rev:1;)

# SIP REGISTER brute force
alert udp $EXTERNAL_NET any -> $HOME_NET 5060 (msg:"LANTANA SIP REGISTER Brute Force"; content:"REGISTER sip:"; nocase; threshold:type threshold, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:9000051; rev:1;)

# SIP INVITE flood
alert udp $EXTERNAL_NET any -> $HOME_NET 5060 (msg:"LANTANA SIP INVITE Flood"; content:"INVITE sip:"; nocase; threshold:type threshold, track by_src, count 20, seconds 60; classtype:attempted-dos; sid:9000052; rev:1;)

# =============================================================================
# Malware download detection (cross-honeypot)
# =============================================================================

# PE executable download to honeypot (Windows malware)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"LANTANA PE Download to Honeypot"; flow:to_client,established; file_data; content:"MZ"; depth:2; content:"This program"; within:200; classtype:trojan-activity; sid:9000060; rev:1;)

# ELF executable download to honeypot (Linux malware)
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"LANTANA ELF Download to Honeypot"; flow:to_client,established; file_data; content:"|7f|ELF"; depth:4; classtype:trojan-activity; sid:9000061; rev:1;)

# Shell script download to honeypot
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"LANTANA Shell Script Download to Honeypot"; flow:to_client,established; file_data; content:"#!/bin/"; depth:7; classtype:trojan-activity; sid:9000062; rev:1;)
