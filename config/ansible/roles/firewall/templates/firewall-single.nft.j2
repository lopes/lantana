# /etc/lantana/honeywall/nftables/firewall.nft
# Managed by Ansible

# ------------------------------------------------------------
# BASE TABLE AND CHAIN DEFINITIONS
# ------------------------------------------------------------

# --- NAT TABLES ---
table ip lantana_nat {
    chain prerouting {
        type nat hook prerouting priority -100; policy accept;
    }
    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
        # Masquerade Sensor Traffic (Generic)
        ip saddr $SENSOR_NET_V4 oifname $WAN_IF masquerade
    }
}

table ip6 lantana_nat6 {
    chain prerouting {
        type nat hook prerouting priority -100; policy accept;
    }
    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
        # Masquerade Sensor Traffic (Generic)
        ip6 saddr $SENSOR_NET_V6 oifname $WAN_IF masquerade
    }
}

# --- FILTER TABLE ---
table inet lantana_filter {
    set allowed_egress_ports {
        type inet_service
        elements = { 53, 67, 80, 123, 443 }
    }

    chain input {
        type filter hook input priority 0; policy drop;

        # 1. CORE SAFETY & STATE
        iifname "lo" accept
        ct state established,related accept
        ct state invalid drop

        # 2. INTELLIGENCE
        ct state new log prefix "[LANTANA_INPUT_NEW] " flags all

        # 3. MANAGEMENT
        tcp dport $SSH_ADMIN_PORT accept

        # 4. ICMP/v6
        icmpv6 type { nd-router-advert, nd-neighbor-solicit, nd-neighbor-advert } accept
        ip protocol icmp accept
        icmpv6 type { echo-request, echo-reply } accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
    }

    chain output {
        type filter hook output priority 0; policy drop;

        # 1. CORE TRAFFIC
        oifname "lo" accept
        ct state established,related accept

        # 2. LOCAL COMMUNICATION
        oifname "ltn0" accept

        # 3. MAINTENANCE PORTS
        udp dport @allowed_egress_ports accept
        tcp dport @allowed_egress_ports accept

        # 4. ICMP EGRESS
        ip protocol icmp accept
        meta l4proto icmpv6 accept

        # 5. LOG BLOCKED OUTBOUND
        limit rate 5/minute log prefix "[LANTANA_OUTPUT_DROP] "
    }
}

# ------------------------------------------------------------
# LOAD PLUGINS
# ------------------------------------------------------------
include "/etc/lantana/honeywall/nftables/sensors/*.nft"

# ------------------------------------------------------------
#  TRAILING RULES: LOG & DROP
# ------------------------------------------------------------
table inet lantana_filter {
    chain input {
        limit rate 10/minute burst 5 packets log prefix "[LANTANA_INPUT_DROP] "
    }

    chain forward {
        limit rate 5/minute burst 5 packets log prefix "[LANTANA_FORWARD_DROP] "
    }
}
