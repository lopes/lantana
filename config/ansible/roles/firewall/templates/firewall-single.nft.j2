# /etc/lantana/honeywall/nftables/firewall.nft
# Managed by Ansible

# --- BASE NAT TABLES ---
table ip lantana_nat {
    chain prerouting {
        type nat hook prerouting priority -100; policy accept;
        # Plugins hook here for DNAT
    }
    chain postrouting {
        type nat hook postrouting priority 100; policy accept;

        # SNAT/Masquerade egressing sensor traffic
        ip saddr $SENSOR_NETS_V4 oifname $WAN_IF masquerade
    }
}

table ip6 lantana_nat6 {
    chain prerouting {
        type nat hook prerouting priority -100; policy accept;
    }
    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
        ip6 saddr $SENSOR_NETS_V6 oifname $WAN_IF masquerade
    }
}

# --- FILTER TABLE ---
table inet lantana_filter {
    set allowed_egress_ports {
        type inet_service
        elements = { 53, 67, 80, 123, 443 }
    }

    chain input {
        type filter hook input priority 0; policy drop;

        # 1. CORE SAFETY & STATE
        iifname "lo" accept
        ct state established,related accept
        ct state invalid drop

        # 2. ANTI-EVASION
        iifname $SENSOR_IF icmpv6 type nd-router-advert drop

        # 3. MANAGEMENT & INFRASTRUCTURE
        tcp dport {{ ansible_port }} accept

        # Allow Collector traffic using the global variables
        iifname $SENSOR_IF ip saddr $COLLECTOR_IPS_V4 tcp dport {{ network.collectors.collector_01.port }} accept
        iifname $SENSOR_IF ip6 saddr $COLLECTOR_IPS_V6 tcp dport {{ network.collectors.collector_01.port }} accept

        # 4. ICMP/v6
        icmpv6 type { nd-neighbor-solicit, nd-neighbor-advert, echo-request, echo-reply } accept
        ip protocol icmp accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;

        # 1. CORE STATE
        ct state established,related accept
        ct state invalid drop

        # 2. STRICT EGRESS INTELLIGENCE
        iifname $SENSOR_IF oifname $WAN_IF ct state new limit rate 10/minute burst 5 packets log prefix "[LANTANA_FORWARD_DROP_EGRESS] " drop
    }

    chain output {
        type filter hook output priority 0; policy drop;

        # 1. CORE TRAFFIC
        oifname "lo" accept
        ct state established,related accept

        # 2. MAINTENANCE
        udp dport @allowed_egress_ports accept
        tcp dport @allowed_egress_ports accept

        # 3. ICMP
        ip protocol icmp accept
        meta l4proto icmpv6 accept

        # 4. LOG DROPS
        limit rate 5/minute log prefix "[LANTANA_OUTPUT_DROP] "
    }
}

# --- LOAD PLUGINS ---
include "/etc/lantana/honeywall/nftables/sensors/*.nft"

# --- TRAILING RULES: TSHOOT LOGGING & DROP ---
table inet lantana_filter {
    chain input {
        limit rate 10/minute burst 5 packets log prefix "[LANTANA_INPUT_DROP] "
    }
    chain forward {
        limit rate 10/minute burst 5 packets log prefix "[LANTANA_FORWARD_DROP] "
    }
}
