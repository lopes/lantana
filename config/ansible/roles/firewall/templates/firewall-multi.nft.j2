#!/usr/sbin/nft -f
# /etc/lantana/honeywall/nftables/firewall.nft
# Managed by Ansible — Multi-node deployment

# --- NAT TABLE: Port Forwarding (DNAT) + Masquerade ---
table ip lantana_nat {
    chain prerouting {
        type nat hook prerouting priority -100; policy accept;
        # Plugins hook here for DNAT (loaded from sensors/*.nft)
    }
    chain postrouting {
        type nat hook postrouting priority 100; policy accept;

        # Masquerade sensor egress traffic
        ip saddr $SENSOR_IP4 oifname $WAN_IF masquerade
    }
}

table ip6 lantana_nat6 {
    chain prerouting {
        type nat hook prerouting priority -100; policy accept;
    }
    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
        ip6 saddr $SENSOR_IP6 oifname $WAN_IF masquerade
    }
}

# --- FILTER TABLE ---
table inet lantana_filter {
    set allowed_egress_ports {
        type inet_service
        elements = { 53, 80, 123, 443 }
    }

    # 1. INPUT: Traffic destined for the honeywall itself
    chain input {
        type filter hook input priority 0; policy drop;

        # Core safety & state
        iifname "lo" accept
        ct state established,related accept
        ct state invalid drop

        # Anti-evasion: block rogue RAs on LAN
        iifname $LAN_IF icmpv6 type nd-router-advert drop

        # Management: admin SSH on custom port
        tcp dport {{ ansible_port }} accept

        # Allow Vector telemetry from sensors and collectors on LAN
        iifname $LAN_IF ip saddr $COLLECTOR_IP4 tcp dport {{ network.collectors.collector_01.port }} accept
        iifname $LAN_IF ip6 saddr $COLLECTOR_IP6 tcp dport {{ network.collectors.collector_01.port }} accept

        # ICMP/ICMPv6 - rate limited
        icmpv6 type { nd-neighbor-solicit, nd-neighbor-advert, echo-request, echo-reply } limit rate 10/second burst 20 packets accept
        ip protocol icmp icmp type echo-request limit rate 10/second burst 20 packets accept
        ip protocol icmp icmp type { destination-unreachable, time-exceeded } accept
    }

    # 2. FORWARD: Traffic passing through the honeywall
    chain forward {
        type filter hook forward priority 0; policy drop;

        # Core state
        ct state established,related accept
        ct state invalid drop

        # Strict egress containment: block new outbound from sensors
        iifname $LAN_IF oifname $WAN_IF ct state new limit rate 10/minute burst 5 packets log prefix "[LANTANA_FORWARD_DROP_EGRESS] " drop
    }

    # 3. OUTPUT: Traffic initiated by the honeywall itself
    chain output {
        type filter hook output priority 0; policy drop;

        # Core traffic
        oifname "lo" accept
        ct state established,related accept

        # Allow LAN communication (honeywall to sensors/collectors)
        oifname $LAN_IF accept

        # Maintenance: DNS, HTTP, NTP, HTTPS
        udp dport @allowed_egress_ports accept
        tcp dport @allowed_egress_ports accept

        # ICMP/ICMPv6
        ip protocol icmp accept
        meta l4proto icmpv6 accept

        # Log drops
        limit rate 5/minute log prefix "[LANTANA_OUTPUT_DROP] "
    }
}

# --- LOAD PLUGINS ---
include "/etc/lantana/honeywall/nftables/sensors/*.nft"

# --- TRAILING RULES: TSHOOT LOGGING & DROP ---
table inet lantana_filter {
    chain input {
        limit rate 10/minute burst 5 packets log prefix "[LANTANA_INPUT_DROP] "
    }
    chain forward {
        limit rate 10/minute burst 5 packets log prefix "[LANTANA_FORWARD_DROP] "
    }
}
