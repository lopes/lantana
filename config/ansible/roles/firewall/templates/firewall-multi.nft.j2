#!/usr/sbin/nft -f
# /etc/lantana/honeywall/nftables/firewall.nft
# Managed by Ansible

flush ruleset

define admin_ssh_port = {{ node_ssh_port }}

# Backend Definitions
define target_ssh_telnet = 10.0.1.2
define target_web = 10.0.1.3

# -------------------------------------------------------------------
# NAT TABLE: Handles Port Forwarding (DNAT)
# -------------------------------------------------------------------
# Update the table definition to 'inet' to support both v4 and v6
table inet lantana_nat {
    chain prerouting {
        type nat hook prerouting priority -100; policy accept;

        # IPv4 DNAT
        ip daddr <YOUR_PUBLIC_IPV4> tcp dport { 22, 23 } dnat to 10.0.1.2
        ip daddr <YOUR_PUBLIC_IPV4> tcp dport { 80, 443 } dnat to 10.0.1.3

        # IPv6 DNAT (If you are NATing IPv6 to internal private IPv6)
        # Note: You need to define the internal IPv6 addresses first
        # ip6 daddr <YOUR_PUBLIC_IPV6> tcp dport { 22, 23 } dnat to <INTERNAL_IPV6_A>
        # ip6 daddr <YOUR_PUBLIC_IPV6> tcp dport { 80, 443 } dnat to <INTERNAL_IPV6_B>
    }

    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
    }
}

# -------------------------------------------------------------------
# FILTER TABLE: Handles Security & Logging
# -------------------------------------------------------------------
table inet lantana_guard {
    set allowed_egress_ports {
        type inet_service
        elements = { 53, 80, 123, 443 }
    }

    # 1. GATE: The Logic Core
    chain lockdown_gate {
        return
    }

    # 2. INPUT DEFENSE: Traffic destined for the Firewall itself
    chain host_defense {
        type filter hook input priority 0; policy drop;

        # Allow Loopback
        iifname "lo" accept

        # Allow Established connections
        ct state established,related accept

        # Allow Admin SSH (on custom port)
        tcp dport $admin_ssh_port accept

        # Allow IPv6 Neighbor Discovery
        icmpv6 type { nd-router-advert, nd-neighbor-solicit, nd-neighbor-advert } accept

        # Log and Drop anything else hitting the firewall directly
        ct state new counter log prefix "[LANTANA_INPUT_DROP] "
    }

    # 3. FORWARD DEFENSE: Traffic passing THROUGH to Backends
    chain forward_defense {
        type filter hook forward priority 0; policy drop;

        # Allow established traffic to flow back and forth
        ct state established,related accept

        # Log new forwarded connections (The Honeypot Traffic)
        ct state new counter log prefix "[LANTANA_FORWARD_HONEYPOT] "

        # [GATE] Check Defcon Status
        jump lockdown_gate

        # Explicitly allow the forwarded traffic defined in NAT
        ip daddr $target_ssh_telnet tcp dport { 22, 23 } accept
        ip daddr $target_web tcp dport { 80, 443 } accept
    }

    # 4. EGRESS: Traffic initiated by the Firewall itself
    chain egress_host {
        type filter hook output priority 0; policy drop;

        oifname "lo" accept
        ct state established,related accept

        # ICMPv6 necessary for network operation
        icmpv6 type { echo-request, echo-reply, nd-router-solicit, nd-router-advert, nd-neighbor-solicit, nd-neighbor-advert } accept

        # Allow Firewall to update, sync time, and run DNS
        udp dport @allowed_egress_ports accept
        tcp dport @allowed_egress_ports accept

        log prefix "[LANTANA_OUTPUT_BLOCK] "
    }
}
