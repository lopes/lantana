# /etc/vector/conf.d/firewall.yaml
# Managed by Ansible

sources:
  in_nftables:
    type: file
    include:
      - /var/log/lantana/honeywall/nftables/firewall.log
    read_from: end

transforms:
  tag_nftables:
    type: remap
    inputs:
      - in_nftables
    source: |-
      .dataset = "nftables"
      .server = "{{ inventory_hostname }}"
      .operation = "{{ narrative.operation_name }}"

  filter_nftables:
    type: filter
    inputs:
      - tag_nftables
    condition:
      type: vrl
      source: |-
        src = to_string(.SRC) ?? to_string(.src_ip) ?? ""
        !starts_with(src, "127.") && src != "::1" && !ip_cidr_contains!("{{ network.prefixes.ipv4 }}", src) && !ip_cidr_contains!("{{ network.prefixes.ipv6 }}", src)
