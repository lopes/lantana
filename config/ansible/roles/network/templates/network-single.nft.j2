# /etc/lantana/honeywall/nftables/network.nft
# Managed by Ansible

# --- INTERFACES ---
define WAN_IF = "{{ network.honeywall.wan.interface }}"
define SENSOR_IF = "{{ network.honeywall.lan.interface }}"

# --- HONEYWALL IPs ---
define WAN_IPV4 = "{{ network.honeywall.wan.ipv4.split('/')[0] }}"
define WAN_IPV6 = "{{ network.honeywall.wan.ipv6.split('/')[0] }}"

# --- SETS ---
# Populated dynamically by Ansible inventory loops.
# Works seamlessly for both N=1 (single-node) and N>1 (multi-node).

table inet lantana_vars {
    # --- COLLECTORS ---
    set collector_ips_v4 {
        type ipv4_addr
        elements = {
            {% for node in network.collectors %}
            {{ node.ipv4.split('/')[0] }}{% if not loop.last %}, {% endif %}
            {% endfor %}
        }
    }

    set collector_ips_v6 {
        type ipv6_addr
        elements = {
            {% for node in network.collectors %}
            {{ node.ipv6.split('/')[0] }}{% if not loop.last %}, {% endif %}
            {% endfor %}
        }
    }

    # --- SENSORS ---
    set sensor_nets_v4 {
        type ipv4_addr
        flags interval
        elements = {
            {% for node in network.sensors.values() %}
            {{ node.ipv4 }}{% if not loop.last %}, {% endif %}
            {% endfor %}
        }
    }

    set sensor_nets_v6 {
        type ipv6_addr
        flags interval
        elements = {
            {% for node in network.sensors.values() %}
            {{ node.ipv6 }}{% if not loop.last %}, {% endif %}
            {% endfor %}
        }
    }
}
