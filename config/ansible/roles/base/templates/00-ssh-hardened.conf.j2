# /etc/ssh/sshd_config.d/00-ssh-hardened.conf
# Managed by Ansible

# --- NETWORK ---
Port {{ ansible_port }}
AddressFamily any

# --- AUTHENTICATION ---
PermitRootLogin no
PubkeyAuthentication yes
PasswordAuthentication no
ChallengeResponseAuthentication no
KbdInteractiveAuthentication no
UsePAM yes
AuthenticationMethods publickey

# --- SESSION HARDENING ---
X11Forwarding no
PrintMotd no
ClientAliveInterval 300
ClientAliveCountMax 0
IgnoreUserKnownHosts yes

# --- ENVIRONMENT ---
AcceptEnv LANG LC_* COLORTERM NO_COLOR

# --- SUBSYSTEM ---
# Use the built-in SFTP server to remain distro-agnostic
# This is required for modern 'scp' and Ansible file transfers
Subsystem sftp internal-sftp
